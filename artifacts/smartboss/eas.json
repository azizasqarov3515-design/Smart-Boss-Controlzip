{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "pnpm": "9.15.4",
      "env": {
        "NPM_CONFIG_FROZEN_LOCKFILE": "false"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "pnpm": "9.15.4",
      "env": {
        "NPM_CONFIG_FROZEN_LOCKFILE": "false"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "pnpm": "9.15.4",
      "env": {
        "NPM_CONFIG_FROZEN_LOCKFILE": "false"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
