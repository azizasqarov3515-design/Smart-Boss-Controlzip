{
  "buildCommand": "cd ../.. && pnpm --filter @workspace/web-app... run build",
  "installCommand": "cd ../.. && pnpm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://smartboss-api-4dmr.onrender.com/api/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
